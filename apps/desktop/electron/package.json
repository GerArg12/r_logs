{
  "name": "r-logs-desktop",
  "version": "0.1.0",
  "description": "Desktop Linux client for the R logs processor",
  "author": {
    "name": "R Logs Team",
    "email": "dev@example.com"
  },
  "homepage": "https://example.com/r-logs",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "dist:linux": "electron-builder --linux AppImage deb"
  },
  "build": {
    "appId": "local.rlogs.desktop",
    "productName": "R Logs Desktop",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "maintainer": "R Logs Team <dev@example.com>"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../shiny",
        "to": "shiny"
      },
      {
        "from": "../../../r-lib",
        "to": "r-lib"
      }
    ]
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
